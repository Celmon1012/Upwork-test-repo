# Supabase (Project Settings → API). Use the anon / publishable key for the client.
# Copy this file to `.env.local` and replace with real values (no quotes needed).
#
# --- Vercel (required or middleware returns MIDDLEWARE_INVOCATION_FAILED) ---
# Dashboard → your project → Settings → Environment Variables.
# Add BOTH keys below for Production (and Preview if you use it). Values must match
# Supabase → Project Settings → API (URL + anon or publishable key). Redeploy after saving.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhlYWxpbmJoc3hoaXpoYnJmbmFrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc0NjE2MTIsImV4cCI6MjA5MzAzNzYxMn0.3N4Arec6d2cZdBgOrxKKTluZ0d9p5BrxZwVrkmuZJUU

# Optional: server-only, for seeding / admin routes — never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=your_secret_service_role_key

# Oral practice (`/practice`): override `question_sets.slug` (default in code: mvp-orals-v1).
# ORAL_QUESTION_SET_SLUG=my-custom-set-slug

# If your rows are still `draft` in Supabase Table Editor, set to 1 so practice can load them.
# ORAL_INCLUDE_DRAFT_QUESTIONS=1
